# ===== Renate env template =====
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Core infra ---
POSTGRES_USER=renate
POSTGRES_PASSWORD=renate
POSTGRES_DB=renate
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://renate:renate@postgres:5432/renate

REDIS_URL=redis://redis:6379

# --- Object storage (MinIO in dev, S3-compatible) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_AUDIO=renate-audio
S3_FORCE_PATH_STYLE=true

# --- Service ports (host-exposed) ---
# Override these if you have something else bound on the host.
API_PORT=3000
DIARIZE_PORT=8000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# --- External APIs (Phases 4-6) ---
SARVAM_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=

# --- Bot runtime (Phase 1+) ---
# Per-session container: SESSION_ID and MEET_URL are set by the worker at
# `docker run` time (or by `docker compose run -e ...` for local testing).
# AUTH_PROFILE is where the mounted auth.json lives inside the container.
AUTH_PROFILE=/auth/auth.json
# SESSION_ID=
# MEET_URL=

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
